# Privacy-filter: vendor source + model weights (2.6 GB, download separately)
python/privacy/_vendor_src/
# Privacy-filter: golden data + swift debug dumps (rebuild via pf_moe_goldens.py)
python/privacy/out/
# Privacy-filter: dangling symlink to out/ (ignored above)
python/privacy/pf_layer0_moe.npz

# Privacy-filter: compiled mlmodelc/mlpackage caches (rebuild via build scripts)
emilio/conv-ane/PF_swift/
emilio/conv-ane/PF_*.mlpackage/
emilio/conv-ane/PF_*.mlmodelc/
emilio/conv-ane/_pf_*/
emilio/conv-ane/_gather_probe/
# Privacy-filter: intermediate bin dumps
emilio/conv-ane/_pf_chain_L*_*.bin
emilio/conv-ane/_pf_topk_*.bin
# Privacy-filter: compiled Swift binaries (rebuild via swiftc)
# Use negation to keep .swift sources
emilio/conv-ane/pf_ane_smoke*
!emilio/conv-ane/pf_ane_smoke*.swift
emilio/conv-ane/pf_attn_probe*
!emilio/conv-ane/pf_attn_probe*.swift
