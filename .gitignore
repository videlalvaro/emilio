!emilio/conv-ane/pf_chain_per_expert.swift
emilio/conv-ane/pf_chain_pipelined
!emilio/conv-ane/pf_chain_pipelined.swift
emilio/conv-ane/pf_chain_profile
!emilio/conv-ane/pf_chain_profile.swift
emilio/conv-ane/pf_e2e
!emilio/conv-ane/pf_e2e.swift

# Gemma ANE: compiled Swift binaries (rebuild via swiftc)
emilio/conv-ane/gemma_ane
emilio/conv-ane/gemma_ane_pe
